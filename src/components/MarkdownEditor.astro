---
// Markdown Editor component using vanilla JS for client-side interactivity
export interface Props {
  slug?: string;
}
const { slug: propSlug } = Astro.props;
---

<div class="markdown-editor">
  <div class="editor-header">
    <h2>Markdown Editor</h2>
    <div class="editor-actions">
      <button id="saveBtn" class="btn btn-primary">Save</button>
      <button id="deleteBtn" class="btn btn-danger">Delete</button>
    </div>
  </div>

  <div id="message" class="message" style="display: none;"></div>

  <div class="editor-container">
    <div class="editor-pane">
      <h3>Editor</h3>
      <textarea id="editor" class="editor-textarea" placeholder="Write your MDX content here..."></textarea>
    </div>
    <div class="preview-pane">
      <h3>Preview</h3>
      <div id="preview" class="preview-content"></div>
    </div>
  </div>
</div>

<style>
  .markdown-editor { padding: 1rem; }
  .editor-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
  .editor-actions { display: flex; gap: 0.5rem; }
  .message { padding: 0.75rem; border-radius: 0.375rem; margin-bottom: 1rem; }
  .message.success { background-color: #d1fae5; color: #036951; }
  .message.error { background-color: #fee2e2; color: #b91c1c; }
  .editor-container { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 768px) { .editor-container { grid-template-columns: 1fr; } }
  .editor-pane, .preview-pane { display: flex; flex-direction: column; }
  .editor-pane h3, .preview-pane h3 { margin-bottom: 0.5rem; font-size: 1rem; font-weight: 600; }
  .editor-textarea {
    width: 100%; min-height: 400px; padding: 1rem;
    font-family: monospace; font-size: 0.875rem;
    border: 1px solid var(--border-color); border-radius: 0.375rem;
    resize: vertical; background-color: var(--bg-secondary); color: var(--text-primary);
  }
  .preview-content {
    width: 100%; min-height: 400px; padding: 1rem;
    border: 1px solid var(--border-color); border-radius: 0.375rem;
    overflow: auto; background-color: white; color: black;
  }
  .btn-danger { background-color: #dc2626; }
  .btn-danger:hover { background-color: #b91c1c; }
</style>

<script is:inline>
  // Parse lang and slug from URL path
  const segments = window.location.pathname.split('/').filter(Boolean);
  const lang = segments[0] || 'ko';
  const slug = segments[segments.length - 1] || '';

  const editor = document.getElementById('editor');
  const preview = document.getElementById('preview');
  const saveBtn = document.getElementById('saveBtn');
  const deleteBtn = document.getElementById('deleteBtn');
  const message = document.getElementById('message');

  function showMessage(text, type = 'success') {
    message.textContent = text;
    message.className = 'message ' + type;
    message.style.display = 'block';
    setTimeout(() => { message.style.display = 'none'; }, 3000);
  }

  // File path: src/content/blog/{lang}/{slug}.mdx
  const filePath = `src/content/blog/${lang}/${slug}.mdx`;

  async function loadContent() {
    const token = localStorage.getItem('github_token');
    if (!token) { showMessage('Please login first', 'error'); return; }

    const owner = localStorage.getItem('github_user') || '';
    const repo = localStorage.getItem('github_repo') || 'blog';

    try {
      const resp = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${filePath}?ref=main`, {
        headers: { 'Authorization': `Bearer ${token}` },
      });

      if (resp.status === 404) {
        // New post template
        const now = new Date();
        const date = now.toISOString().split('T')[0];
        editor.value = `---
title: "New Post (${lang})"
date: "${date}"
lang: "${lang}"
tags: []
summary: ""
category: "general"
---

# New Post

Write your content here...
`;
        preview.textContent = editor.value;
      } else {
        const data = await resp.json();
        const content = decodeURIComponent(escape(atob(data.content)));
        editor.value = content;
        preview.textContent = content;
      }
    } catch (err) {
      showMessage('Failed to load content: ' + err.message, 'error');
    }
  }

  async function saveContent() {
    const token = localStorage.getItem('github_token');
    if (!token) { showMessage('Please login first', 'error'); return; }

    const owner = localStorage.getItem('github_user') || '';
    const repo = localStorage.getItem('github_repo') || 'blog';

    try {
      let sha = null;
      const shaResp = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${filePath}?ref=main`, {
        headers: { 'Authorization': `Bearer ${token}` },
      });

      if (shaResp.ok) {
        const shaData = await shaResp.json();
        sha = shaData.sha;
      }

      const body = {
        message: `Update ${lang}/${slug}.mdx`,
        content: btoa(unescape(encodeURIComponent(editor.value))),
        branch: 'main',
      };
      if (sha) body.sha = sha;

      const resp = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${filePath}`, {
        method: 'PUT',
        headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (resp.ok) {
        showMessage('Saved successfully!');
      } else {
        const error = await resp.json();
        showMessage('Failed to save: ' + (error.message || 'Unknown error'), 'error');
      }
    } catch (err) {
      showMessage('Failed to save: ' + err.message, 'error');
    }
  }

  async function deleteContent() {
    if (!confirm('Are you sure you want to delete this post?')) return;

    const token = localStorage.getItem('github_token');
    if (!token) { showMessage('Please login first', 'error'); return; }

    const owner = localStorage.getItem('github_user') || '';
    const repo = localStorage.getItem('github_repo') || 'blog';

    try {
      const shaResp = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${filePath}?ref=main`, {
        headers: { 'Authorization': `Bearer ${token}` },
      });

      if (shaResp.status === 404) { showMessage('File not found', 'error'); return; }

      const shaData = await shaResp.json();

      const resp = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${filePath}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: `Delete ${lang}/${slug}.mdx`, sha: shaData.sha, branch: 'main' }),
      });

      if (resp.ok) {
        showMessage('Deleted successfully!');
        setTimeout(() => { window.location.href = `/${lang}/blog`; }, 1000);
      } else {
        const error = await resp.json();
        showMessage('Failed to delete: ' + (error.message || 'Unknown error'), 'error');
      }
    } catch (err) {
      showMessage('Failed to delete: ' + err.message, 'error');
    }
  }

  editor.addEventListener('input', () => { preview.textContent = editor.value; });
  saveBtn.addEventListener('click', saveContent);
  deleteBtn.addEventListener('click', deleteContent);

  loadContent();
</script>
