---
export interface Props {
  lang: string;
}

const { lang } = Astro.props;
---

<footer style="border-top: 1px solid var(--border-color); padding: 2rem 0; margin-top: 3rem; text-align: center; color: var(--text-secondary); font-size: 0.875rem;">
  <div class="container">
    <p>&copy; {new Date().getFullYear()} Blog & Portfolio. Built with Astro & GitHub Pages.</p>
    <p style="margin-top: 0.5rem;">
      <a href={`/${lang}/admin`}>
        {lang === 'ko' ? '관리자 설정' : lang === 'ja' ? '管理者設定' : 'Admin'}
      </a>
    </p>
  </div>
</footer>
