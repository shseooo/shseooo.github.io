---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
};

const { slug } = Astro.params;
const { post } = Astro.props;
const { Content } = await render(post);

// slug is "ko/welcome" - parse lang from it
const slashIndex = slug.indexOf('/');
const lang = slug.substring(0, slashIndex);
const postSlug = slug.substring(slashIndex + 1);

const backLabel = lang === 'ko' ? '← 목록으로' : lang === 'ja' ? '← 一覧へ' : '← Back to list';
---

<BaseLayout title={post.data.title} lang={lang}>
  <div class="container mx-auto px-4 py-12">
    <article class="prose prose-lg max-w-none">
      <h1>{post.data.title}</h1>
      <div class="text-gray-500 mb-8">
        <time>{post.data.date.toLocaleDateString('en-US')}</time>
        {post.data.tags.length > 0 && (
          <div class="flex gap-2 mt-2">
            {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
          </div>
        )}
      </div>
      <Content />
    </article>
    <div class="mt-8">
      <a href={`/${lang}/blog`} class="btn btn-secondary">{backLabel}</a>
    </div>
  </div>
</BaseLayout>
