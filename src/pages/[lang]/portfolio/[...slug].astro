---
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return ['ko', 'en', 'ja'].flatMap((lang) =>
    ['hello-world', 'todo-app'].map((slug) => ({ params: { lang, slug } }))
  );
}

const lang = Astro.params.lang;
const slug = Astro.params.slug;
const title = lang === 'ko' ? '포트폴리오' : lang === 'ja' ? 'ポートフォリオ' : 'Portfolio';
const backLabel = lang === 'ko' ? '← 목록으로' : lang === 'ja' ? '← 一覧へ' : '← Back to list';
---

<BaseLayout title={title} lang={lang}>
  <div class="container mx-auto px-4 py-12">
    <div class="mb-4">
      <a href={`/${lang}/portfolio`} class="btn btn-secondary">{backLabel}</a>
    </div>
    <div class="border rounded-lg overflow-hidden" style="height: 70vh;">
      <iframe src={`/portfolio/${slug}/`} style="width: 100%; height: 100%; border: none;" title={slug} />
    </div>
  </div>
</BaseLayout>
