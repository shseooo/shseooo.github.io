---
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return ['ko', 'en', 'ja'].map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang;
const portfolioItems = [
  { slug: 'hello-world', title: { ko: 'Hello World', en: 'Hello World', ja: 'Hello World' }, desc: { ko: '첫 번째 프로그램', en: 'First program', ja: '最初のプログラム' } },
  { slug: 'todo-app', title: { ko: 'TODO 앱', en: 'Todo App', ja: 'TODOアプリ' }, desc: { ko: '간단한 TODO 리스트', en: 'Simple todo list', ja: 'シンプルなTODOリスト' } },
];
const title = lang === 'ko' ? '포트폴리오' : lang === 'ja' ? 'ポートフォリオ' : 'Portfolio';
---

<BaseLayout title={title} lang={lang}>
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-8">{title}</h1>
    <div class="grid md:grid-cols-2 gap-6">
      {portfolioItems.map((item) => (
        <a href={`/portfolio/${item.slug}/`} class="card block">
          <h2 class="text-xl font-semibold mb-2">{item.title[lang]}</h2>
          <p class="text-gray-600">{item.desc[lang]}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
