---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MarkdownEditor from '@/components/MarkdownEditor.astro';

export async function getStaticPaths() {
  return ['ko', 'en', 'ja'].map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang;
const title = lang === 'ko' ? '에디터' : lang === 'ja' ? 'エディター' : 'Editor';
---

<BaseLayout title={title} lang={lang}>
  <div class="container mx-auto px-4 py-8">
    <div class="mb-4">
      <a href={`/${lang}/blog`} class="btn btn-secondary">
        {lang === 'ko' ? '← 뒤로' : lang === 'ja' ? '← 戻る' : '← Back'}
      </a>
    </div>
    <MarkdownEditor />
  </div>
</BaseLayout>
