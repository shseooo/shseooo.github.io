---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return ['ko', 'en', 'ja'].map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang;
const allPosts = await getCollection('blog', ({ data }) => data.lang === lang);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const title = lang === 'ko' ? '블로그' : lang === 'ja' ? 'ブログ' : 'Blog';
const noPosts = lang === 'ko' ? '게시글이 없습니다.' : lang === 'ja' ? '投稿が見つかりません。' : 'No posts found.';
const newPost = lang === 'ko' ? '새 글 작성' : lang === 'ja' ? '新しい投稿を作成' : 'New Post';
const edit = lang === 'ko' ? '수정' : lang === 'ja' ? '編集' : 'Edit';
---

<BaseLayout title={title} lang={lang}>
  <div class="container mx-auto px-4 py-12">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-bold">{title}</h1>
      <a href={`/${lang}/blog/editor`} class="btn btn-primary">{newPost}</a>
    </div>
    {posts.length === 0 ? (
      <p class="text-gray-500">{noPosts}</p>
    ) : (
      <div class="grid gap-6">
        {posts.map((post) => (
          <div class="card">
            <div class="flex justify-between items-start">
          <div class="flex-1">
              <h2 class="text-xl font-semibold mb-2">
                <a href={`/blog/${post.id}`} class="hover:underline">{post.data.title}</a>
              </h2>
              <p class="text-gray-600 mb-2">{post.data.summary}</p>
              <div class="flex gap-2 text-sm text-gray-500">
                <span>{post.data.date.toLocaleDateString('en-US')}</span>
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
            <a href={`/${lang}/blog/editor`} class="btn btn-secondary ml-4">{edit}</a>
          </div>
        </div>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
