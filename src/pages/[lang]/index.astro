---
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return ['ko', 'en', 'ja'].map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang;
const titles = { ko: '홈', en: 'Home', ja: '홈' };
const subtitles = { ko: '생각을 나누고, 작품을 소개합니다', en: 'Sharing thoughts and showcasing work', ja: '考えを分け合い、作品を紹介' };
const blogDesc = { ko: '기술 블로그 글을 읽어보세요', en: 'Read technical blog posts', ja: '技術ブログの記事を読む' };
const portfolioDesc = { ko: '작은 프로그램들을 확인해보세요', en: 'Check out small programs', ja: '小さなプログラムを確認' };
---

<BaseLayout title={titles[lang]} lang={lang}>
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-4">{titles[lang]}</h1>
    <p class="text-xl text-gray-600 mb-8">{subtitles[lang]}</p>
    <div class="grid md:grid-cols-2 gap-6">
      <a href={`/${lang}/blog`} class="card">
        <h2 class="text-2xl font-semibold mb-2">{lang === 'ko' ? '블로그' : lang === 'ja' ? 'ブログ' : 'Blog'}</h2>
        <p class="text-gray-600">{blogDesc[lang]}</p>
      </a>
      <a href={`/${lang}/portfolio`} class="card">
        <h2 class="text-2xl font-semibold mb-2">{lang === 'ko' ? '포트폴리오' : lang === 'ja' ? 'ポートフォリオ' : 'Portfolio'}</h2>
        <p class="text-gray-600">{portfolioDesc[lang]}</p>
      </a>
    </div>
  </div>
</BaseLayout>
