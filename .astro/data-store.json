[["Map",1,2,41,42],"blog",["Map",3,4,17,18,29,30],"en/welcome",{"id":3,"data":5,"body":13,"filePath":14,"digest":15,"deferredRender":16},{"title":6,"date":7,"lang":8,"tags":9,"summary":11,"category":12},"First Blog Post",["Date","2024-01-01T00:00:00.000Z"],"en",[10,1],"astro","First post of the blog built with Astro.","general","# First Blog Post\n\nWelcome! This is the first post of the static blog built with Astro.\n\n## Features\n\n- Markdown and MDX support\n- Multi-language support (Korean, English, Japanese)\n- GitHub Pages deployment\n- Dark/Light theme\n\n## Tech Stack\n\n- Astro\n- Tailwind CSS\n- GitHub API\n\nThis blog stores posts as MDX files in a GitHub repository and can be written and edited from the web editor.","src/content/blog/en/welcome.mdx","b9397315f6901d11",true,"ja/welcome",{"id":17,"data":19,"body":26,"filePath":27,"digest":28,"deferredRender":16},{"title":20,"date":21,"lang":22,"tags":23,"summary":25,"category":12},"最初のブログ投稿",["Date","2024-01-01T00:00:00.000Z"],"ja",[10,24],"ブログ","Astroで作ったブログの最初の投稿です。","# 最初のブログ投稿\n\nようこそ！これはAstroで作った静的ブログの最初の投稿です。\n\n## 特徴\n\n- MarkdownおよびMDX対応\n- 多言語対応（韓国語、英語、日本語）\n- GitHub Pagesデプロイ\n- ダーク/ライトテーマ\n\n## 技術スタック\n\n- Astro\n- Tailwind CSS\n- GitHub API\n\nこのブログはGitHubリポジトリにMDXファイルとして保存され、Webエディターで作成・編集できます。","src/content/blog/ja/welcome.mdx","ccb17a946ce8be71","ko/welcome",{"id":29,"data":31,"body":38,"filePath":39,"digest":40,"deferredRender":16},{"title":32,"date":33,"lang":34,"tags":35,"summary":37,"category":12},"첫 번째 블로그 포스트",["Date","2024-01-01T00:00:00.000Z"],"ko",[10,36],"블로그","Astro로 만든 블로그의 첫 번째 포스트입니다.","# 첫 번째 블로그 포스트\n\n환영합니다! 이것은 Astro로 만든 정적 블로그의 첫 번째 포스트입니다.\n\n## 특징\n\n- Markdown 및 MDX 지원\n- 다국어 지원 (한국어, 영어, 일본어)\n- GitHub Pages 배포\n- 다크/라이트 테마\n\n## 기술 스택\n\n- Astro\n- Tailwind CSS\n- GitHub API\n\n이 블로그는 GitHub 리포지토리에 MDX 파일로 저장되며, 웹 에디터에서 작성하고 수정할 수 있습니다.","src/content/blog/ko/welcome.mdx","dbab137bc1cc2847","meta::meta",["Map",43,44,45,46,47,48],"astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"static\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":true,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":false,\"port\":4321,\"allowedHosts\":[]},\"redirects\":{},\"image\":{\"endpoint\":{\"route\":\"/_image\"},\"service\":{\"entrypoint\":\"astro/assets/services/sharp\",\"config\":{}},\"dangerouslyProcessSVG\":false,\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":{\"backticks\":true,\"closingQuotes\":{\"double\":\"”\",\"single\":\"’\"},\"dashes\":true,\"ellipses\":true,\"openingQuotes\":{\"double\":\"“\",\"single\":\"‘\"},\"quotes\":true}},\"i18n\":{\"defaultLocale\":\"ko\",\"locales\":[\"ko\",\"en\",\"ja\"],\"routing\":{\"prefixDefaultLocale\":false,\"redirectToDefaultLocale\":false,\"fallbackType\":\"redirect\"}},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"csp\":false,\"actionBodySizeLimit\":1048576,\"serverIslandBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"prerenderConflictBehavior\":\"warn\",\"experimental\":{\"advancedRouting\":false,\"clientPrerender\":false,\"contentIntellisense\":false,\"chromeDevtoolsWorkspace\":false,\"rustCompiler\":false,\"queuedRendering\":{\"enabled\":false}},\"legacy\":{\"collectionsBackwardsCompat\":false}}","astro-version","6.3.8","content-config-digest","233f4bde626533fd"]