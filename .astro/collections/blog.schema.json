{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "lang": {
      "default": "ko",
      "type": "string",
      "enum": [
        "ko",
        "en",
        "ja"
      ]
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "default": "",
      "type": "string"
    },
    "cover": {
      "type": "string"
    },
    "category": {
      "default": "general",
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}